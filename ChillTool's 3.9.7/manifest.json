{
  "manifest_version": 3,
  "name": "ChillTool's | IP lookup for umingle",
  "description": "ip lookup and more!",
  "version": "3.9.7",
  "icons": {
    "16": "logo/chilltools_16.png",
    "48": "logo/chilltools_48.png",
    "128": "logo/chilltools_128.png"
  },
  "host_permissions": [
    "https://uhmegle.com/*",
    "https://umingle.com/*"
  ],
  "permissions": [
    "https://uhmegle.com/*",
    "https://umingle.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://uhmegle.com/*",
        "https://umingle.com/*"
      ],
      "js": ["scripts/uhmegle.js"],
      "world": "MAIN"
    }
  ]
}